{
  "formatter": {
    "lineWidth": 88,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "style": {
        "noUselessElse": "off",
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noShadowRestrictedNames": "off",
        "noControlCharactersInRegex": "off"
      },
      "complexity": {
        "noStaticOnlyClass": "off"
      }
    }
  },
  "organizeImports": {
    "enabled": false
  }
}
