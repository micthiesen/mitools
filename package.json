    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.13.0",
  "files": [
    "dist",
    "tsconfig",
    "biome.shared.json"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
